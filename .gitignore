# Minimal, project-specific .gitignore for this repo

# Python bytecode
__pycache__/
*.py[cod]

# Virtual environments
.venv/
venv/
env/

# Packaging artifacts
build/
dist/
*.egg-info/

# Tool caches
.ruff_cache/
.mypy_cache/
.pytest_cache/
pytest_cache/

# Editor/IDE
.vscode/
.idea/

# Local env / secrets
.env
.env.*
local_settings.py

# OS
.DS_Store
Thumbs.db

# Logs and databases
*.log
*.db
*.sqlite3

# Docs
docs/_build/
